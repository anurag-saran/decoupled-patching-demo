<?xml version="1.0" encoding="UTF-8"?>
<!--
  FAT variant. Note the difference from the thin build's version of this file:
  there is NO dependency on an external Log4j module, because in the Fat WAR the
  Log4j JARs are bundled inside WEB-INF/lib. We still exclude the server's logging
  subsystem so the app uses its own bundled Log4j.

  Consequence: to patch Log4j here, you must rebuild this WAR. There is no module to swap.
-->
<jboss-deployment-structure xmlns="urn:jboss:deployment-structure:1.2">
  <deployment>
    <exclude-subsystems>
      <subsystem name="logging"/>
    </exclude-subsystems>
  </deployment>
</jboss-deployment-structure>
