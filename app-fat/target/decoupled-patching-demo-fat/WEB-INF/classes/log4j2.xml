<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Log4j2 config. Note: this file does not enable or disable the vulnerability —
  whether ${jndi:...} lookups are evaluated is a property of the log4j-core LIBRARY version
  supplied by the server module, which is exactly what the demo swaps.
-->
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <Logger name="com.redhat.demo" level="info" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Root level="info">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
